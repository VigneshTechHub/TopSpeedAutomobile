@model List<VehicleTypeModel>
@{
    int count = 0;
}
<div class="container">
    <div class="row">
        <div class="col-md-6 text-uppercase">
            <h1>Vehicle Type List</h1>
        </div>
        <div class="col-md-6 text-end">
            <a asp-area="Admin" asp-Controller="VehicleType" asp-action="Create" class="btn btn-primary"> <i class="bi bi-plus-circle"></i>Create</a>
        </div>
    </div>
    <hr />

    @if (Model.Count > 0)
    {
        <table id="table" class="table table-bordered table-striped">

            <thead>

                <tr>
                    <th class="text-center">S.No</th>

                    <th class="text-center">Name</th>

                    <th class="text-center">Action</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>
                       
                        <td class="text-center" width="20%">@(++count)</td>
                        <td width="60%">@item.Name</td>
                        <td class="d-flex align-items-center justify-content-center">

                            <div class="w-75 btn-group" role="group">

                                <a asp-area="Admin" asp-controller="VehicleType" asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-info" data-toggle="tooltip" data-placement="top" title="Detail">

                                    <i class="bi bi-info-circle"></i>
                                </a>

                                <a asp-area="Admin" asp-controller="VehicleType" asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-warning" data-toggle="tooltip" data-placement="top" title="Edit">

                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-area="Admin" asp-controller="VehicleType" asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-danger" data-toggle="tooltip" data-placement="top" title="Delete">

                                    <i class="bi bi-trash"></i>

                                </a>

                            </div>

                        </td>

                    </tr>
                }
            </tbody>

        </table>

    }
    else
    {

        <div class="container">

            <div class="row">

                <div class="col-md-12">

                    <h2 class="text-warning text-uppercase text-center"> No Records to show </h2>

                </div>

            </div>

        </div>
       
    }

</div>
@section scripts
{
    <script>
        $('.table').DataTable();
    </script>
}